#!/usr/bin/env python3
"""
devpulse — daily dev digest for software engineers
Usage: devpulse [--lang python|go|rust|...] [--topics ai,cli,...] [--no-browser]
"""

import argparse
import html as html_mod
import json
import os
import re
import subprocess
import textwrap
import xml.etree.ElementTree as ET
from datetime import date, datetime, timezone
from email.utils import parsedate_to_datetime
from pathlib import Path
from urllib.request import urlopen, Request
from urllib.error import URLError

# ── config (edit these defaults) ──────────────────────────────────────────────
DEFAULT_LANGUAGES = ["python", "typescript", "go", "rust", "javascript"]
DEFAULT_TOPICS    = ["ai", "llm", "cli", "devtools", "open source", "security",
                     "performance", "kubernetes", "wasm", "api"]
HN_STORY_COUNT    = 15
HN_SHOW_COUNT     = 8
GH_SHOW_COUNT     = 8
BREACH_SHOW_COUNT = 12  # breach/hack news items to show

BREACH_SOURCES = [
    ("The Hacker News",   "https://feeds.feedburner.com/TheHackersNews"),
    ("BleepingComputer",  "https://www.bleepingcomputer.com/feed/"),
    ("Krebs on Security", "https://krebsonsecurity.com/feed/"),
    ("SecurityWeek",      "https://feeds.feedburner.com/securityweek"),
]

BREACH_KEYWORDS = [
    "hack", "breach", "ransomware", "data leak", "stolen", "compromised",
    "cyberattack", "cyber attack", "phishing", "malware", "exploit",
    "vulnerability", "zero-day", "zero day", "credential", "exfiltrat",
    "extort", "dump", "exposed", "infiltrat", "intrusion",
]
# ──────────────────────────────────────────────────────────────────────────────

RESET  = "\033[0m"
BOLD   = "\033[1m"
DIM    = "\033[2m"
CYAN   = "\033[36m"
YELLOW = "\033[33m"
GREEN  = "\033[32m"
MAGENTA= "\033[35m"

def fetch_json(url):
    try:
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=8) as r:
            return json.loads(r.read())
    except (URLError, json.JSONDecodeError) as e:
        print(f"{DIM}  [fetch failed: {e}]{RESET}")
        return None

def fetch_text(url):
    try:
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=8) as r:
            return r.read().decode("utf-8", errors="replace")
    except URLError as e:
        print(f"{DIM}  [fetch failed: {e}]{RESET}")
        return None

# ── Hacker News ───────────────────────────────────────────────────────────────

def get_hn_stories(topics, count=HN_STORY_COUNT, show=HN_SHOW_COUNT):
    print(f"{DIM}  fetching Hacker News...{RESET}", end="\r")
    ids = fetch_json("https://hacker-news.firebaseio.com/v0/topstories.json")
    if not ids:
        return []

    stories = []
    for sid in ids[:count * 3]:
        s = fetch_json(f"https://hacker-news.firebaseio.com/v0/item/{sid}.json")
        if s and s.get("type") == "story" and s.get("title"):
            stories.append(s)
        if len(stories) >= count * 3:
            break

    def relevance(s):
        title = (s.get("title") or "").lower()
        url   = (s.get("url") or "").lower()
        hits  = sum(1 for t in topics if t in title or t in url)
        return (hits, s.get("score", 0))

    return sorted(stories, key=relevance, reverse=True)[:show]

def print_hn(stories):
    print(f"\n{BOLD}{YELLOW}◆ Hacker News — Top Stories{RESET}")
    print(f"{DIM}  {'─'*62}{RESET}")
    for i, s in enumerate(stories, 1):
        title  = s.get("title", "untitled")
        points = s.get("score", 0)
        comms  = s.get("descendants", 0)
        url    = s.get("url") or f"https://news.ycombinator.com/item?id={s['id']}"
        domain = url.split("/")[2] if url.startswith("http") else "HN"
        print(f"\n  {BOLD}{i:>2}. {title}{RESET}")
        print(f"      {DIM}{domain}  ·  {points}pts  ·  {comms} comments{RESET}")
        print(f"      {DIM}{url[:80]}{RESET}")

# ── GitHub Trending ───────────────────────────────────────────────────────────

def get_gh_trending(languages, show=GH_SHOW_COUNT):
    import re
    results = []
    seen = set()

    for lang in languages[:3]:
        print(f"{DIM}  fetching GitHub trending ({lang})...{RESET}", end="\r")
        html = fetch_text(f"https://github.com/trending/{lang}?since=daily")
        if not html:
            continue

        articles = re.findall(r'<article[^>]*class="Box-row"[^>]*>(.*?)</article>', html, re.S)
        for art in articles:
            name_m = re.search(r'href="/([\w-]+/[\w.-]+)"', art)
            if not name_m:
                continue
            repo_path = name_m.group(1)
            if repo_path in seen or "/" not in repo_path:
                continue
            seen.add(repo_path)

            desc_m  = re.search(r'<p\s+class="col-9[^"]*"[^>]*>(.*?)</p>', art, re.S)
            desc    = re.sub(r'<[^>]+>', '', desc_m.group(1)).strip() if desc_m else ""
            stars_m = re.findall(r'[\d,]+(?=\s*</span>)', art)
            stars   = stars_m[0].replace(",", "") if stars_m else "?"
            today_m = re.search(r'([\d,]+)\s+stars\s+today', art)
            today   = today_m.group(1) if today_m else "?"

            results.append({"repo": repo_path, "desc": desc[:120],
                            "stars": stars, "today": today, "lang": lang})
            if len(results) >= show:
                break
        if len(results) >= show:
            break

    return results[:show]

def print_gh(repos):
    print(f"\n{BOLD}{GREEN}◆ GitHub Trending — Today{RESET}")
    print(f"{DIM}  {'─'*62}{RESET}")
    for i, r in enumerate(repos, 1):
        print(f"\n  {BOLD}{i:>2}. {CYAN}{r['repo']}{RESET}")
        print(f"      {textwrap.fill(r['desc'] or '(no description)', 72, subsequent_indent='      ')}")
        print(f"      {DIM}⭐ {r['stars']} total  ·  +{r['today']} today  ·  {r['lang']}{RESET}")

# ── Breach / Hack News ───────────────────────────────────────────────────────

def fetch_rss(name, url):
    try:
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=8) as r:
            return ET.fromstring(r.read())
    except Exception as e:
        print(f"{DIM}  [rss failed: {name} — {e}]{RESET}")
        return None

def parse_rss_date(raw):
    try:
        return parsedate_to_datetime(raw).astimezone(timezone.utc)
    except Exception:
        return datetime.min.replace(tzinfo=timezone.utc)

def get_breach_news(show=BREACH_SHOW_COUNT):
    items = []
    for name, url in BREACH_SOURCES:
        print(f"{DIM}  fetching {name}...{RESET}", end="\r")
        root = fetch_rss(name, url)
        if root is None:
            continue
        for item in root.findall(".//item"):
            title = (item.findtext("title") or "").strip()
            link  = (item.findtext("link")  or "").strip()
            date_raw = item.findtext("pubDate") or ""
            desc_raw = item.findtext("description") or ""
            desc  = re.sub(r"<[^>]+>", "", desc_raw).strip()[:200]

            text = (title + " " + desc).lower()
            if not any(kw in text for kw in BREACH_KEYWORDS):
                continue

            items.append({
                "title":  title,
                "link":   link,
                "source": name,
                "date":   parse_rss_date(date_raw),
                "date_raw": date_raw,
                "desc":   desc,
            })

    items.sort(key=lambda x: x["date"], reverse=True)
    return items[:show]

def print_breach(items):
    RED = "\033[31m"
    print(f"\n{BOLD}{RED}◆ Security Breaches & Hacks — Latest{RESET}")
    print(f"{DIM}  {'─'*62}{RESET}")
    for i, item in enumerate(items, 1):
        title  = item["title"]
        source = item["source"]
        dt     = item["date"].strftime("%-d %b %Y") if item["date"] != datetime.min.replace(tzinfo=timezone.utc) else "?"
        print(f"\n  {BOLD}{i:>2}. {title}{RESET}")
        print(f"      {DIM}{source}  ·  {dt}{RESET}")
        print(f"      {DIM}{item['link'][:80]}{RESET}")

# ── HTML page ─────────────────────────────────────────────────────────────────

def build_html(today_str, stories, repos, breach_items):
    def hn_cards(stories):
        out = []
        for s in stories:
            title  = html_mod.escape(s.get("title", "untitled"))
            points = s.get("score", 0)
            comms  = s.get("descendants", 0)
            url    = s.get("url") or f"https://news.ycombinator.com/item?id={s['id']}"
            hn_url = f"https://news.ycombinator.com/item?id={s['id']}"
            domain = url.split("/")[2] if url.startswith("http") else "news.ycombinator.com"
            out.append(f"""
            <div class="card">
              <a class="title" href="{html_mod.escape(url)}" target="_blank">{title}</a>
              <div class="meta">
                <span>{html_mod.escape(domain)}</span>
                <span>▲ {points} pts</span>
                <a href="{html_mod.escape(hn_url)}" target="_blank">{comms} comments</a>
              </div>
            </div>""")
        return "\n".join(out)

    def breach_cards(items):
        out = []
        for item in items:
            title  = html_mod.escape(item["title"])
            source = html_mod.escape(item["source"])
            link   = html_mod.escape(item["link"])
            dt     = item["date"].strftime("%-d %b %Y") if item["date"] != datetime.min.replace(tzinfo=timezone.utc) else "?"
            desc   = html_mod.escape(item["desc"])
            out.append(f"""
            <div class="card breach-card">
              <a class="title" href="{link}" target="_blank">{title}</a>
              <div class="desc">{desc}</div>
              <div class="meta">
                <span>{source}</span>
                <span class="breach-date">📅 {dt}</span>
              </div>
            </div>""")
        return "\n".join(out)

    def gh_cards(repos):
        out = []
        for r in repos:
            repo  = html_mod.escape(r["repo"])
            desc  = html_mod.escape(r["desc"] or "(no description)")
            stars = r["stars"]
            today = r["today"]
            lang  = html_mod.escape(r["lang"])
            gh_url = f"https://github.com/{r['repo']}"
            out.append(f"""
            <div class="card">
              <a class="title repo" href="{html_mod.escape(gh_url)}" target="_blank">{repo}</a>
              <div class="desc">{desc}</div>
              <div class="meta">
                <span>⭐ {stars}</span>
                <span>+{today} today</span>
                <span class="lang-badge">{lang}</span>
              </div>
            </div>""")
        return "\n".join(out)

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>devpulse · {html_mod.escape(today_str)}</title>
<style>
  :root {{
    --bg: #0d1117; --surface: #161b22; --border: #30363d;
    --text: #e6edf3; --muted: #8b949e; --accent: #58a6ff;
    --green: #3fb950; --orange: #f0883e; --purple: #d2a8ff;
  }}
  * {{ box-sizing: border-box; margin: 0; padding: 0; }}
  body {{ background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; padding: 2rem 1rem; }}
  .container {{ max-width: 860px; margin: 0 auto; }}
  header {{ margin-bottom: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1.25rem; }}
  header h1 {{ font-size: 1.6rem; letter-spacing: -.5px; }}
  header h1 span {{ color: var(--accent); }}
  header .date {{ color: var(--muted); font-size: .9rem; margin-top: .3rem; }}
  section {{ margin-bottom: 2.5rem; }}
  section h2 {{ font-size: 1.1rem; color: var(--muted); text-transform: uppercase;
                letter-spacing: 1px; margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem; }}
  section h2::before {{ content: ""; display: block; width: 3px; height: 1.1rem;
                         border-radius: 2px; background: var(--accent); }}
  .card {{ background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
           padding: 1rem 1.25rem; margin-bottom: .75rem; transition: border-color .15s; }}
  .card:hover {{ border-color: var(--accent); }}
  .card .title {{ font-size: 1rem; font-weight: 600; color: var(--text);
                  text-decoration: none; display: block; margin-bottom: .4rem; line-height: 1.4; }}
  .card .title:hover {{ color: var(--accent); }}
  .card .title.repo {{ color: var(--green); font-family: ui-monospace, monospace; font-size: .95rem; }}
  .card .title.repo:hover {{ color: var(--accent); }}
  .card .desc {{ color: var(--muted); font-size: .88rem; margin-bottom: .5rem; line-height: 1.5; }}
  .card .meta {{ display: flex; gap: 1rem; font-size: .8rem; color: var(--muted); flex-wrap: wrap; }}
  .card .meta a {{ color: var(--muted); text-decoration: none; }}
  .card .meta a:hover {{ color: var(--accent); }}
  .lang-badge {{ background: #21262d; border: 1px solid var(--border); border-radius: 12px;
                 padding: .1rem .55rem; font-size: .75rem; color: var(--purple); }}
  footer {{ color: var(--muted); font-size: .8rem; border-top: 1px solid var(--border);
            padding-top: 1rem; margin-top: 1rem; }}
  .breach-card {{ border-left: 3px solid #f85149; }}
  .breach-date {{ color: #f85149; }}
  .refresh-btn {{
    display: inline-flex; align-items: center; gap: .4rem;
    background: none; border: 1px solid var(--border); border-radius: 6px;
    color: var(--muted); font-size: .82rem; padding: .3rem .75rem;
    cursor: pointer; transition: border-color .15s, color .15s;
  }}
  .refresh-btn:hover {{ border-color: var(--accent); color: var(--accent); }}
  .refresh-btn.spinning svg {{ animation: spin .8s linear infinite; }}
  .refresh-btn.done {{ border-color: var(--green); color: var(--green); }}
  @keyframes spin {{ to {{ transform: rotate(360deg); }} }}
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>dev<span>pulse</span></h1>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:.4rem;">
      <div class="date">{html_mod.escape(today_str)}</div>
      <button class="refresh-btn" id="refreshBtn" onclick="doRefresh()">
        <svg id="refreshIcon" width="13" height="13" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10"/>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        Refresh
      </button>
    </div>
  </header>

  <section>
    <h2>Hacker News</h2>
    {hn_cards(stories)}
  </section>

  <section>
    <h2>GitHub Trending</h2>
    {gh_cards(repos)}
  </section>

  <section>
    <h2>🔴 Security Breaches &amp; Hacks</h2>
    {breach_cards(breach_items)}
  </section>

  <footer>Generated by devpulse · <code>devpulse --help</code> to customize</footer>

<script>
async function doRefresh() {{
  const btn  = document.getElementById('refreshBtn');
  btn.disabled = true;
  btn.classList.add('spinning');
  btn.querySelector('span,#refreshIcon') && null;
  btn.innerHTML = `<svg id="refreshIcon" width="13" height="13" viewBox="0 0 24 24" fill="none"
    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="23 4 23 10 17 10"/>
    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Refreshing…`;
  try {{
    const res = await fetch('http://localhost:8081/refresh', {{ method: 'POST' }});
    if (res.ok) {{
      btn.classList.remove('spinning');
      btn.classList.add('done');
      btn.innerHTML = '✓ Done — reloading…';
      setTimeout(() => location.reload(), 800);
    }} else {{
      throw new Error('server error');
    }}
  }} catch(e) {{
    btn.classList.remove('spinning');
    btn.textContent = '✗ Failed';
    btn.disabled = false;
    setTimeout(() => {{
      btn.textContent = 'Refresh';
      btn.classList.remove('done');
    }}, 2000);
  }}
}}
</script>
</div>
</body>
</html>"""

def open_browser(path):
    subprocess.Popen(["xdg-open", f"file://{path}"],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

# ── main ──────────────────────────────────────────────────────────────────────

def main():
    ap = argparse.ArgumentParser(description="Daily dev digest")
    ap.add_argument("--lang",       default=",".join(DEFAULT_LANGUAGES))
    ap.add_argument("--topics",     default=",".join(DEFAULT_TOPICS))
    ap.add_argument("--no-hn",      action="store_true")
    ap.add_argument("--no-gh",      action="store_true")
    ap.add_argument("--no-browser", action="store_true", help="Print to terminal only")
    args = ap.parse_args()

    languages = [l.strip().lower() for l in args.lang.split(",")   if l.strip()]
    topics    = [t.strip().lower() for t in args.topics.split(",") if t.strip()]
    today_str = date.today().strftime("%A, %B %-d %Y")

    print(f"\n{BOLD}{MAGENTA}{'━'*66}{RESET}")
    print(f"{BOLD}{MAGENTA}  devpulse  ·  {today_str}{RESET}")
    print(f"{BOLD}{MAGENTA}{'━'*66}{RESET}")

    stories, repos, breach_items = [], [], []

    if not args.no_hn:
        stories = get_hn_stories(topics)
        print(" " * 50, end="\r")
        if stories:
            print_hn(stories)

    if not args.no_gh:
        repos = get_gh_trending(languages)
        print(" " * 50, end="\r")
        if repos:
            print_gh(repos)

    breach_items = get_breach_news()
    print(" " * 50, end="\r")
    if breach_items:
        print_breach(breach_items)

    print(f"\n{DIM}{'─'*66}")
    print(f"  Customize: devpulse --lang go,rust --topics security,wasm")
    print(f"  Terminal only: devpulse --no-browser{RESET}\n")

    if not args.no_browser and (stories or repos or breach_items):
        page = Path.home() / ".devpulse" / "devpulse.html"
        page.write_text(build_html(today_str, stories, repos, breach_items))
        open_browser("http://localhost:8080/devpulse.html")

if __name__ == "__main__":
    main()
