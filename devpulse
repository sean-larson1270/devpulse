# ── Recent Commits ────────────────────────────────────────────────────────────

def get_recent_commits(show=COMMITS_SHOW):
    print(f"{DIM}  fetching recent commits...{RESET}", end="\r")
    try:
        who = subprocess.run(["gh", "api", "user", "-q", ".login"],
                             capture_output=True, text=True, timeout=5)
        account = who.stdout.strip() or "?"
        r = subprocess.run(
            ["gh", "api", "/user/repos?per_page=20&sort=pushed"],
            capture_output=True, text=True, timeout=10
        )
        if r.returncode != 0:
            return [], account
        repos = json.loads(r.stdout or "[]")
        commits = []
        for repo in repos[:COMMITS_REPOS]:
            full_name = repo["full_name"]
            cr = subprocess.run(
                ["gh", "api", f"/repos/{full_name}/commits?per_page=3"],
                capture_output=True, text=True, timeout=8
            )
            if cr.returncode != 0:
                continue
            for c in json.loads(cr.stdout or "[]"):
                msg  = c.get("commit", {}).get("message", "").split("\n")[0][:100]
                dt   = c.get("commit", {}).get("committer", {}).get("date", "")
                sha  = (c.get("sha") or "")[:7]
                url  = c.get("html_url", f"https://github.com/{full_name}")
                commits.append({"sha": sha, "msg": msg, "date": dt, "repo": full_name, "url": url})
        commits.sort(key=lambda x: x.get("date", ""), reverse=True)
        return commits[:show], account
    except Exception:
        return [], "?"

def print_commits(commits, account):
    print(f"\n{BOLD}{MAGENTA}◆ Recent Commits — {account}{RESET}")
    print(f"{DIM}  {'─'*62}{RESET}")
