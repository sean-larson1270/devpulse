def get_gh_notifications():
    print(f"{DIM}  fetching GitHub notifications...{RESET}", end="\r")
    try:
        r = subprocess.run(
            ["gh", "api", "notifications", "--paginate"],
            capture_output=True, text=True, timeout=10
        )
        if r.returncode != 0:
            return [], "unknown"
        items = json.loads(r.stdout or "[]")
        # get active account name
        who = subprocess.run(["gh", "api", "user", "-q", ".login"],
                             capture_output=True, text=True, timeout=5)
        account = who.stdout.strip() or "?"
        out = []
        for n in items:
            subj = n.get("subject", {})
            repo = n.get("repository", {}).get("full_name", "")
            out.append({
                "title":  subj.get("title", ""),
                "type":   subj.get("type", ""),
                "repo":   repo,
                "url":    f"https://github.com/{repo}",
                "unread": n.get("unread", False),
                "date":   n.get("updated_at", ""),
            })
        out.sort(key=lambda x: x["date"], reverse=True)
        return out[:15], account
    except Exception:
        return [], "?"

def print_gh_notifications(items, account):
