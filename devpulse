def fetch_rss(name, url):
    try:
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=8) as r:
            return ET.fromstring(r.read())
    except Exception as e:
        print(f"{DIM}  [rss failed: {name} — {e}]{RESET}")
        return None

def parse_rss_date(raw):
    try:
        return parsedate_to_datetime(raw).astimezone(timezone.utc)
    except Exception:
        return datetime.min.replace(tzinfo=timezone.utc)

def get_breach_news(show=BREACH_SHOW_COUNT):
    items = []
    for name, url in BREACH_SOURCES:
        print(f"{DIM}  fetching {name}...{RESET}", end="\r")
        root = fetch_rss(name, url)
        if root is None:
            continue
        for item in root.findall(".//item"):
            title = (item.findtext("title") or "").strip()
            link  = (item.findtext("link")  or "").strip()
            date_raw = item.findtext("pubDate") or ""
            desc_raw = item.findtext("description") or ""
            desc  = re.sub(r"<[^>]+>", "", desc_raw).strip()[:200]

            text = (title + " " + desc).lower()
            if not any(kw in text for kw in BREACH_KEYWORDS):
                continue

            items.append({
                "title":  title,
                "link":   link,
                "source": name,
                "date":   parse_rss_date(date_raw),
                "date_raw": date_raw,
                "desc":   desc,
            })

    items.sort(key=lambda x: x["date"], reverse=True)
    return items[:show]

