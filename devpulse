    --bg: #0d1117; --surface: #161b22; --border: #30363d;
    --text: #e6edf3; --muted: #8b949e; --accent: #58a6ff;
    --green: #3fb950; --orange: #f0883e; --purple: #d2a8ff;
  }}
  * {{ box-sizing: border-box; margin: 0; padding: 0; }}
  body {{ background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; padding: 2rem 1rem; }}
  .container {{ max-width: 860px; margin: 0 auto; }}
  header {{ margin-bottom: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1.25rem; }}
  header h1 {{ font-size: 1.6rem; letter-spacing: -.5px; }}
  header h1 span {{ color: var(--accent); }}
  header .date {{ color: var(--muted); font-size: .9rem; margin-top: .3rem; }}
  section {{ margin-bottom: 2.5rem; }}
  section h2 {{ font-size: 1.1rem; color: var(--muted); text-transform: uppercase;
                letter-spacing: 1px; margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem; }}
  section h2::before {{ content: ""; display: block; width: 3px; height: 1.1rem;
                         border-radius: 2px; background: var(--accent); }}
  .card {{ background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
           padding: 1rem 1.25rem; margin-bottom: .75rem; transition: border-color .15s; }}
  .card:hover {{ border-color: var(--accent); }}
  .card .title {{ font-size: 1rem; font-weight: 600; color: var(--text);
                  text-decoration: none; display: block; margin-bottom: .4rem; line-height: 1.4; }}
  .card .title:hover {{ color: var(--accent); }}
  .card .title.repo {{ color: var(--green); font-family: ui-monospace, monospace; font-size: .95rem; }}
  .card .title.repo:hover {{ color: var(--accent); }}
  .card .desc {{ color: var(--muted); font-size: .88rem; margin-bottom: .5rem; line-height: 1.5; }}
  .card .meta {{ display: flex; gap: 1rem; font-size: .8rem; color: var(--muted); flex-wrap: wrap; }}
  .card .meta a {{ color: var(--muted); text-decoration: none; }}
  .card .meta a:hover {{ color: var(--accent); }}
  .lang-badge {{ background: #21262d; border: 1px solid var(--border); border-radius: 12px;
                 padding: .1rem .55rem; font-size: .75rem; color: var(--purple); }}
  footer {{ color: var(--muted); font-size: .8rem; border-top: 1px solid var(--border);
            padding-top: 1rem; margin-top: 1rem; }}
  .breach-card {{ border-left: 3px solid #f85149; }}
  .breach-date {{ color: #f85149; }}
  .unread {{ border-left: 3px solid var(--accent); }}
  .status-dot {{ width: 8px; height: 8px; border-radius: 50%; display:inline-block; flex-shrink:0; }}
  .dot-up {{ background: var(--green); box-shadow: 0 0 4px var(--green); }}
  .dot-down {{ background: #f85149; }}
  .answered {{ color: var(--green); }}
  .repo-name {{ color: var(--green); font-family: ui-monospace, monospace; font-size: .78rem; }}
  .sha-badge {{ background: #21262d; border: 1px solid var(--border); border-radius: 4px;
                padding: .05rem .4rem; font-family: ui-monospace, monospace; font-size: .75rem; color: var(--orange); }}
  .refresh-btn {{
    display: inline-flex; align-items: center; gap: .4rem;
    background: none; border: 1px solid var(--border); border-radius: 6px;
    color: var(--muted); font-size: .82rem; padding: .3rem .75rem;
    cursor: pointer; transition: border-color .15s, color .15s;
  }}
  .refresh-btn:hover {{ border-color: var(--accent); color: var(--accent); }}
  .refresh-btn.spinning svg {{ animation: spin .8s linear infinite; }}
  .refresh-btn.done {{ border-color: var(--green); color: var(--green); }}
  @keyframes spin {{ to {{ transform: rotate(360deg); }} }}
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>dev<span>pulse</span></h1>
    <div style="display:flex;align-items:center;gap:1rem;margin-top:.4rem;">
      <div class="date">{html_mod.escape(today_str)}</div>
      <button class="refresh-btn" id="refreshBtn" onclick="doRefresh()">
        <svg id="refreshIcon" width="13" height="13" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10"/>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        Refresh
      </button>
    </div>
  </header>

  <section>
    <h2>Hacker News</h2>
    {hn_cards(stories)}
  </section>

  <section>
    <h2>GitHub Trending</h2>
    {gh_cards(repos)}
  </section>

  <section>
    <h2>🔴 Security Breaches &amp; Hacks</h2>
    {breach_cards(breach_items)}
  </section>

  <section>
    <h2>Recent Releases</h2>
    {release_cards(releases)}
  </section>

  <section>
    <h2>Stack Overflow — Hot Questions</h2>
    {so_cards(so_questions)}
  </section>

  <section>
    <h2>Recent Commits — {html_mod.escape(commits_account)}</h2>
    {commit_cards(commits, commits_account)}
  </section>

  <section>
    <h2>GitHub Notifications — {html_mod.escape(gh_account)}</h2>
    {notification_cards(notifications, gh_account)}
  </section>

  <section>
    <h2>Docker Containers</h2>
    {docker_cards(containers)}
  </section>

  <footer>Generated by devpulse · <code>devpulse --help</code> to customize</footer>

<script>
async function doRefresh() {{
  const btn  = document.getElementById('refreshBtn');
  btn.disabled = true;
  btn.classList.add('spinning');
  btn.querySelector('span,#refreshIcon') && null;
  btn.innerHTML = `<svg id="refreshIcon" width="13" height="13" viewBox="0 0 24 24" fill="none"
    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="23 4 23 10 17 10"/>
    <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Refreshing…`;
  try {{
    const res = await fetch('http://localhost:8081/refresh', {{ method: 'POST' }});
    if (res.ok) {{
      btn.classList.remove('spinning');
      btn.classList.add('done');
      btn.innerHTML = '✓ Done — reloading…';
      setTimeout(() => location.reload(), 800);
    }} else {{
      throw new Error('server error');
    }}
  }} catch(e) {{
    btn.classList.remove('spinning');
    btn.textContent = '✗ Failed';
    btn.disabled = false;
    setTimeout(() => {{
      btn.textContent = 'Refresh';
      btn.classList.remove('done');
    }}, 2000);
  }}
}}
</script>
</div>
</body>
</html>"""

def open_browser(path):
    subprocess.Popen(["xdg-open", f"file://{path}"],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

# ── main ──────────────────────────────────────────────────────────────────────

def main():
    ap = argparse.ArgumentParser(description="Daily dev digest")
    ap.add_argument("--lang",       default=",".join(DEFAULT_LANGUAGES))
    ap.add_argument("--topics",     default=",".join(DEFAULT_TOPICS))
    ap.add_argument("--no-hn",      action="store_true")
    ap.add_argument("--no-gh",      action="store_true")
    ap.add_argument("--no-browser", action="store_true", help="Print to terminal only")
    args = ap.parse_args()

    languages = [l.strip().lower() for l in args.lang.split(",")   if l.strip()]
    topics    = [t.strip().lower() for t in args.topics.split(",") if t.strip()]
    today_str = date.today().strftime("%A, %B %-d %Y")

    print(f"\n{BOLD}{MAGENTA}{'━'*66}{RESET}")
    print(f"{BOLD}{MAGENTA}  devpulse  ·  {today_str}{RESET}")
    print(f"{BOLD}{MAGENTA}{'━'*66}{RESET}")

    stories, repos, breach_items = [], [], []
    notifications, gh_account, containers = [], "?", []
    so_questions, commits, commits_account = [], [], "?"
    releases = []

    if not args.no_hn:
        stories = get_hn_stories(topics)
        print(" " * 50, end="\r")
        if stories:
            print_hn(stories)

    if not args.no_gh:
        repos = get_gh_trending(languages)
        print(" " * 50, end="\r")
        if repos:
            print_gh(repos)

    breach_items = get_breach_news()
    print(" " * 50, end="\r")
    if breach_items:
        print_breach(breach_items)

    releases = get_releases()
    print(" " * 50, end="\r")
    if releases:
        print_releases(releases)

    so_questions = get_so_questions()
    print(" " * 50, end="\r")
    if so_questions:
        print_so(so_questions)

    commits, commits_account = get_recent_commits()
    print(" " * 50, end="\r")
    if commits:
        print_commits(commits, commits_account)

    notifications, gh_account = get_gh_notifications()
    print(" " * 50, end="\r")
    if notifications:
        print_gh_notifications(notifications, gh_account)

    containers = get_docker_status()
    print(" " * 50, end="\r")
    if containers:
        print_docker(containers)

    print(f"\n{DIM}{'─'*66}")
    print(f"  Customize: devpulse --lang go,rust --topics security,wasm")
    print(f"  Terminal only: devpulse --no-browser{RESET}\n")

    if stories or repos or breach_items:
        page = Path.home() / ".devpulse" / "devpulse.html"
        page.write_text(build_html(today_str, stories, repos, breach_items,
                                   notifications, gh_account, containers,
                                   so_questions, commits, commits_account, releases))
        if not args.no_browser:
            open_browser("http://localhost:8080/devpulse.html")

if __name__ == "__main__":
    main()
