def fetch_json(url):
    try:
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=8) as r:
            return json.loads(r.read())
    except (URLError, json.JSONDecodeError) as e:
        print(f"{DIM}  [fetch failed: {e}]{RESET}")
        return None

def fetch_text(url):
    try:
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=8) as r:
            return r.read().decode("utf-8", errors="replace")
    except URLError as e:
        print(f"{DIM}  [fetch failed: {e}]{RESET}")
        return None

# ── Hacker News ───────────────────────────────────────────────────────────────

def get_hn_stories(topics, count=HN_STORY_COUNT, show=HN_SHOW_COUNT):
    print(f"{DIM}  fetching Hacker News...{RESET}", end="\r")
    ids = fetch_json("https://hacker-news.firebaseio.com/v0/topstories.json")
    if not ids:
        return []

    stories = []
    for sid in ids[:count * 3]:
        s = fetch_json(f"https://hacker-news.firebaseio.com/v0/item/{sid}.json")
        if s and s.get("type") == "story" and s.get("title"):
            stories.append(s)
        if len(stories) >= count * 3:
            break

    def relevance(s):
        title = (s.get("title") or "").lower()
        url   = (s.get("url") or "").lower()
        hits  = sum(1 for t in topics if t in title or t in url)
        return (hits, s.get("score", 0))

    return sorted(stories, key=relevance, reverse=True)[:show]

def print_hn(stories):
    print(f"\n{BOLD}{YELLOW}◆ Hacker News — Top Stories{RESET}")
    print(f"{DIM}  {'─'*62}{RESET}")
    for i, s in enumerate(stories, 1):
        title  = s.get("title", "untitled")
        points = s.get("score", 0)
        comms  = s.get("descendants", 0)
        url    = s.get("url") or f"https://news.ycombinator.com/item?id={s['id']}"
        domain = url.split("/")[2] if url.startswith("http") else "HN"
        print(f"\n  {BOLD}{i:>2}. {title}{RESET}")
        print(f"      {DIM}{domain}  ·  {points}pts  ·  {comms} comments{RESET}")
        print(f"      {DIM}{url[:80]}{RESET}")

# ── GitHub Trending ───────────────────────────────────────────────────────────

def get_gh_trending(languages, show=GH_SHOW_COUNT):
    import re
    results = []
    seen = set()

    for lang in languages[:3]:
        print(f"{DIM}  fetching GitHub trending ({lang})...{RESET}", end="\r")
        html = fetch_text(f"https://github.com/trending/{lang}?since=daily")
        if not html:
            continue

        articles = re.findall(r'<article[^>]*class="Box-row"[^>]*>(.*?)</article>', html, re.S)
        for art in articles:
            name_m = re.search(r'href="/([\w-]+/[\w.-]+)"', art)
            if not name_m:
                continue
            repo_path = name_m.group(1)
            if repo_path in seen or "/" not in repo_path:
                continue
            seen.add(repo_path)

            desc_m  = re.search(r'<p\s+class="col-9[^"]*"[^>]*>(.*?)</p>', art, re.S)
            desc    = re.sub(r'<[^>]+>', '', desc_m.group(1)).strip() if desc_m else ""
            stars_m = re.findall(r'[\d,]+(?=\s*</span>)', art)
            stars   = stars_m[0].replace(",", "") if stars_m else "?"
            today_m = re.search(r'([\d,]+)\s+stars\s+today', art)
            today   = today_m.group(1) if today_m else "?"

            results.append({"repo": repo_path, "desc": desc[:120],
                            "stars": stars, "today": today, "lang": lang})
            if len(results) >= show:
                break
        if len(results) >= show:
            break

    return results[:show]

