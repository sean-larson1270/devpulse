        print(f"\n  {BOLD}{i:>2}. {c['msg']}{RESET}")
        print(f"      {DIM}{c['repo']}  ·  {c['sha']}  ·  {dt}{RESET}")

# ── Release Tracker ───────────────────────────────────────────────────────────

def get_releases(repos=RELEASE_WATCH, within_days=RELEASE_DAYS):
    print(f"{DIM}  fetching releases...{RESET}", end="\r")
    from datetime import timedelta
    cutoff = datetime.now(timezone.utc) - timedelta(days=within_days)
    results = []
    for repo in repos:
        try:
            r = subprocess.run(
                ["gh", "api", f"/repos/{repo}/releases/latest"],
                capture_output=True, text=True, timeout=6
            )
            if r.returncode != 0:
                continue
            rel  = json.loads(r.stdout)
            tag  = rel.get("tag_name", "")
            date = rel.get("published_at", "")
            url  = rel.get("html_url", f"https://github.com/{repo}/releases")
            if not date:
                continue
            dt = datetime.fromisoformat(date.replace("Z", "+00:00"))
            if dt < cutoff:
                continue
            results.append({"repo": repo, "tag": tag, "date": date[:10], "url": url})
        except Exception:
            continue
    results.sort(key=lambda x: x["date"], reverse=True)
    return results

