#!/usr/bin/env python3
"""Tiny server for devpulse. Listens on 127.0.0.1:8081."""

from http.server import HTTPServer, BaseHTTPRequestHandler
import json
import os
import socket
import subprocess
from urllib.parse import urlparse, parse_qs
from urllib.request import urlopen, Request

# ── config ────────────────────────────────────────────────────────────────────
DEV_PORTS = [
    (3000,  "React / Node"),
    (3001,  "Alt dev server"),
    (4000,  "Phoenix / misc"),
    (5000,  "Flask / misc"),
    (5173,  "Vite"),
    (5432,  "PostgreSQL"),
    (6379,  "Redis"),
    (8000,  "Django / Python"),
    (8080,  "devpulse nginx"),
    (8081,  "devpulse server"),
    (8888,  "Jupyter"),
    (9000,  "SonarQube / misc"),
    (27017, "MongoDB"),
]
# ──────────────────────────────────────────────────────────────────────────────

def _cors(handler):
    handler.send_header("Access-Control-Allow-Origin", "*")
    handler.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")

# ── weather ───────────────────────────────────────────────────────────────────

def reverse_geocode(lat, lon):
    try:
        req = Request(
            f"https://nominatim.openstreetmap.org/reverse?lat={lat}&lon={lon}&format=json",
            headers={"User-Agent": "devpulse/1.0"}
        )
        with urlopen(req, timeout=5) as r:
            addr = json.loads(r.read()).get("address", {})
        city  = addr.get("city") or addr.get("town") or addr.get("village") or addr.get("hamlet") or ""
        state = addr.get("state", "")
        return city, state
    except Exception:
        return "", ""

def ip_location():
    try:
        req = Request("http://ip-api.com/json/", headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=5) as r:
            d = json.loads(r.read())
        if d.get("status") == "success":
            return d["lat"], d["lon"]
    except Exception:
        pass
    return None, None

def get_weather(browser_lat=None, browser_lon=None):
    try:
        if browser_lat and browser_lon:
            lat, lon = float(browser_lat), float(browser_lon)
            city, state = reverse_geocode(lat, lon)
            location_label = f"{city}, {state}".strip(", ") if city else None
        else:
            lat, lon = ip_location()
            location_label = None

        location_str = f"{lat},{lon}" if lat and lon else ""
        req = Request(f"https://wttr.in/{location_str}?format=j1",
                      headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=6) as r:
            data = json.loads(r.read())
        c     = data["current_condition"][0]
        today = data.get("weather", [{}])[0]
        return {
            "temp_f":   c.get("temp_F", "?"),
            "feels_f":  c.get("FeelsLikeF", "?"),
            "desc":     c["weatherDesc"][0]["value"] if c.get("weatherDesc") else "?",
            "humidity": c.get("humidity", "?"),
            "wind_mph": c.get("windspeedMiles", "?"),
            "wind_dir": c.get("winddir16Point", "?"),
            "high_f":   today.get("maxtempF", "?"),
            "low_f":    today.get("mintempF", "?"),
            "location": location_label,
        }
    except Exception:
        return {}

# ── system stats ──────────────────────────────────────────────────────────────

def get_system_stats():
    stats = {}
    try:
        # RAM from /proc/meminfo
        mem = {}
        with open("/proc/meminfo") as f:
            for line in f:
                k, v = line.split(":", 1)
                mem[k.strip()] = int(v.split()[0])
        total_mb = mem["MemTotal"] // 1024
        avail_mb = mem["MemAvailable"] // 1024
        used_mb  = total_mb - avail_mb
        stats["ram_used_gb"]  = round(used_mb  / 1024, 1)
        stats["ram_total_gb"] = round(total_mb / 1024, 1)
        stats["ram_pct"]      = round(used_mb / total_mb * 100)

        # CPU load from /proc/loadavg
        with open("/proc/loadavg") as f:
            parts = f.read().split()
        stats["load_1"]  = parts[0]
        stats["load_5"]  = parts[1]
        stats["load_15"] = parts[2]

        # Disk usage for /
        sv = os.statvfs("/")
        disk_total = sv.f_blocks * sv.f_frsize
        disk_free  = sv.f_bfree  * sv.f_frsize
        disk_used  = disk_total  - disk_free
        stats["disk_used_gb"]  = round(disk_used  / 1024**3, 1)
        stats["disk_total_gb"] = round(disk_total / 1024**3, 1)
        stats["disk_pct"]      = round(disk_used / disk_total * 100)
    except Exception:
        pass
    return stats

# ── port scanner ──────────────────────────────────────────────────────────────

def scan_ports():
    results = []
    for port, label in DEV_PORTS:
        try:
            with socket.create_connection(("127.0.0.1", port), timeout=0.15):
                results.append({"port": port, "label": label, "up": True})
        except Exception:
            results.append({"port": port, "label": label, "up": False})
    return results

# ── docker + github ───────────────────────────────────────────────────────────

def get_docker():
    try:
        r = subprocess.run(["docker", "ps", "-a", "--format", "{{json .}}"],
                           capture_output=True, text=True, timeout=8)
        return [json.loads(l) for l in r.stdout.strip().splitlines() if l]
    except Exception:
        return []

def get_notifications():
    try:
        r = subprocess.run(["gh", "api", "notifications"],
                           capture_output=True, text=True, timeout=10)
        who = subprocess.run(["gh", "api", "user", "-q", ".login"],
                             capture_output=True, text=True, timeout=5)
        account = who.stdout.strip() or "?"
        if r.returncode != 0:
            return [], account
        items = []
        for n in json.loads(r.stdout or "[]"):
            subj = n.get("subject", {})
            repo = n.get("repository", {}).get("full_name", "")
            items.append({
                "title":  subj.get("title", ""),
                "type":   subj.get("type", ""),
                "repo":   repo,
                "url":    f"https://github.com/{repo}",
                "unread": n.get("unread", False),
                "date":   n.get("updated_at", ""),
            })
        return items, account
    except Exception:
        return [], "?"

# ── status endpoint ───────────────────────────────────────────────────────────

def get_status_data(browser_lat=None, browser_lon=None):
    notifications, gh_account = get_notifications()
    return {
        "containers":    get_docker(),
        "notifications": notifications,
        "gh_account":    gh_account,
        "weather":       get_weather(browser_lat, browser_lon),
        "system":        get_system_stats(),
        "ports":         scan_ports(),
    }


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith("/api/status"):
            qs   = parse_qs(urlparse(self.path).query)
            blat = qs.get("lat", [None])[0]
            blon = qs.get("lon", [None])[0]
            body = json.dumps(get_status_data(blat, blon)).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            _cors(self)
            self.end_headers()
            self.wfile.write(body)
        elif self.path == "/tasks":
            tasks_file = os.path.expanduser("~/.devpulse/tasks.md")
            content = open(tasks_file).read() if os.path.exists(tasks_file) else ""
            body = json.dumps({"content": content}).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            _cors(self)
            self.end_headers()
            self.wfile.write(body)
        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        if self.path == "/tasks":
            length  = int(self.headers.get("Content-Length", 0))
            payload = json.loads(self.rfile.read(length) or b"{}")
            content = payload.get("content", "")
            tasks_file = os.path.expanduser("~/.devpulse/tasks.md")
            open(tasks_file, "w").write(content)
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            _cors(self)
            self.end_headers()
            self.wfile.write(b'{"ok":true}')
        elif self.path == "/refresh":
            result = subprocess.run(["devpulse", "--no-browser"],
                                    capture_output=True, text=True)
            ok = result.returncode == 0
            self.send_response(200 if ok else 500)
            self.send_header("Content-Type", "application/json")
            _cors(self)
            self.end_headers()
            self.wfile.write(b'{"ok":true}' if ok else b'{"ok":false}')
        else:
            self.send_response(404)
            self.end_headers()

    def do_OPTIONS(self):
        self.send_response(200)
        _cors(self)
        self.end_headers()

    def log_message(self, *args):
        pass

if __name__ == "__main__":
    HTTPServer(("127.0.0.1", 8081), Handler).serve_forever()
