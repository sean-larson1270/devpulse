#!/usr/bin/env python3
"""Tiny server for devpulse. Listens on 127.0.0.1:8081."""

from http.server import HTTPServer, BaseHTTPRequestHandler
import json
import subprocess
from urllib.request import urlopen, Request
from urllib.error import URLError

def _cors(handler):
    handler.send_header("Access-Control-Allow-Origin", "*")
    handler.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")

def get_location():
    try:
        req = Request("http://ip-api.com/json/", headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=5) as r:
            d = json.loads(r.read())
        if d.get("status") == "success":
            return d["lat"], d["lon"], d["city"], d["regionName"]
    except Exception:
        pass
    return None, None, None, None

def get_weather():
    try:
        lat, lon, city, region = get_location()
        if lat and lon:
            location_str = f"{lat},{lon}"
            location_label = f"{city}, {region}" if city else None
        else:
            location_str = ""
            location_label = None

        url = f"https://wttr.in/{location_str}?format=j1"
        req = Request(url, headers={"User-Agent": "devpulse/1.0"})
        with urlopen(req, timeout=6) as r:
            data = json.loads(r.read())
        c = data["current_condition"][0]
        today = data.get("weather", [{}])[0]
        return {
            "temp_f":   c.get("temp_F", "?"),
            "feels_f":  c.get("FeelsLikeF", "?"),
            "desc":     c["weatherDesc"][0]["value"] if c.get("weatherDesc") else "?",
            "humidity": c.get("humidity", "?"),
            "wind_mph": c.get("windspeedMiles", "?"),
            "wind_dir": c.get("winddir16Point", "?"),
            "high_f":   today.get("maxtempF", "?"),
            "low_f":    today.get("mintempF", "?"),
            "location": location_label,
        }
    except Exception:
        return {}

def get_status_data():
    containers = []
    try:
        r = subprocess.run(["docker", "ps", "-a", "--format", "{{json .}}"],
                           capture_output=True, text=True, timeout=8)
        containers = [json.loads(l) for l in r.stdout.strip().splitlines() if l]
    except Exception:
        pass

    notifications = []
    gh_account = "?"
    try:
        r = subprocess.run(["gh", "api", "notifications"],
                           capture_output=True, text=True, timeout=10)
        if r.returncode == 0:
            raw = json.loads(r.stdout or "[]")
            for n in raw:
                subj = n.get("subject", {})
                repo = n.get("repository", {}).get("full_name", "")
                notifications.append({
                    "title":  subj.get("title", ""),
                    "type":   subj.get("type", ""),
                    "repo":   repo,
                    "url":    f"https://github.com/{repo}",
                    "unread": n.get("unread", False),
                    "date":   n.get("updated_at", ""),
                })
        who = subprocess.run(["gh", "api", "user", "-q", ".login"],
                             capture_output=True, text=True, timeout=5)
        gh_account = who.stdout.strip() or "?"
    except Exception:
        pass

    weather = get_weather()
    return {"containers": containers, "notifications": notifications,
            "gh_account": gh_account, "weather": weather}


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/api/status":
            data = get_status_data()
            body = json.dumps(data).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            _cors(self)
            self.end_headers()
            self.wfile.write(body)
        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        if self.path == "/refresh":
            result = subprocess.run(
                ["devpulse", "--no-browser"],
                capture_output=True, text=True
            )
            ok = result.returncode == 0
            self.send_response(200 if ok else 500)
            self.send_header("Content-Type", "application/json")
            _cors(self)
            self.end_headers()
            self.wfile.write(b'{"ok":true}' if ok else b'{"ok":false}')
        else:
            self.send_response(404)
            self.end_headers()

    def do_OPTIONS(self):
        self.send_response(200)
        _cors(self)
        self.end_headers()

    def log_message(self, *args):
        pass

if __name__ == "__main__":
    server = HTTPServer(("127.0.0.1", 8081), Handler)
    server.serve_forever()
